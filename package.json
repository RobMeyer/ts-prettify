{
  "name": "ts-prettify",
  "version": "0.1.0",
  "description": "Prettify<T> utility type that flattens intersections while preserving built-in types, plus a TS Language Service Plugin for VS Code hover tooltips.",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "require": "./dist/plugin/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && tsc -p tsconfig.plugin.json && cp plugin/package.json dist/plugin/package.json",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:typecheck": "vitest typecheck",
    "setup": "chmod +x .githooks/pre-commit && git config core.hooksPath .githooks",
    "format": "oxfmt src plugin vite.config.ts",
    "format:check": "oxfmt --check src plugin vite.config.ts",
    "lint": "oxlint src plugin vite.config.ts",
    "lint:fix": "oxlint --fix src plugin vite.config.ts"
  },
  "devDependencies": {
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
